# Database
MONGO_URI=

# Auth
JWT_SECRET=change-this-to-a-long-random-string

# Stripe ($20/mo subscription)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
CALLTWIN_PRICE_ID=
SETUP_FEE_PRICE_ID=   # optional — one-time $299 setup fee price ID, added to checkout automatically if set
LIFETIME_PRICE_ID=    # one-time $1,000 lifetime access price ID (mode: payment, no monthly charge)

# Twilio (calling + SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1...

# ElevenLabs (voice cloning + TTS)
ELEVENLABS_API_KEY=

# Anthropic (live call conversation AI)
ANTHROPIC_API_KEY=

# Your deployed backend's public URL — Render gives you this after
# first deploy. Twilio MUST be able to reach this over HTTPS.
# Example: https://calltwin-backend-xxxx.onrender.com
PUBLIC_BASE_URL=

PORT=3000
