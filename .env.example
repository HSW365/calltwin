# ===== MONGODB (reuse your existing Atlas cluster, new db name) =====
MONGODB_URI=mongodb+srv://hoodstarent365_db_user:YOUR_PASSWORD@hsw365.nfrszmg.mongodb.net/queenee-assistant?retryWrites=true&w=majority

# ===== BUSINESS PROFILE (what the AI receptionist represents) =====
